# ─────────────────────────────────────────────────────────────────────────────
# Marcador — Variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo:  cp .env.example .env
# 2. Rellena los valores  (nunca subas el .env a Git)
# ─────────────────────────────────────────────────────────────────────────────

# API key de football-data.org (plan gratuito: sin límite diario, 10 req/min)
# Consíguela en: https://www.football-data.org/client/register
FOOTBALL_API_KEY=pon_aqui_tu_api_key

# URL pública del sitio (necesaria para og:image y canonical en producción)
# En local puedes dejarlo vacío o poner http://localhost:4321
# En Vercel se rellena automáticamente con VERCEL_URL, pero es mejor poner
# tu dominio final cuando lo tengas: https://marcador.live
# SITE=https://marcador.live
